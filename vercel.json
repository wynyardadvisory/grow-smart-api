{
  "version": 2,
  "builds": [
    { "src": "api.js", "use": "@vercel/node" }
  ],
  "routes": [
    { "src": "/(.*)", "dest": "api.js" }
  ],
  "crons": [
    { "path": "/cron/daily", "schedule": "0 6 * * *" },
    { "path": "/cron/push-morning", "schedule": "30 7 * * *" },
    { "path": "/cron/push-evening", "schedule": "0 18 * * *" }
  ]
}
